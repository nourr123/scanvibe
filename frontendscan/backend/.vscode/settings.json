{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": true
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/uploads": true,
    "**/.git": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/uploads": true
  },
  "emmet.includeLanguages": {
    "javascript": "javascriptreact"
  },
  "javascript.suggest.autoImports": true,
  "typescript.suggest.autoImports": true,
  "files.associations": {
    "*.js": "javascript"
  }
} 